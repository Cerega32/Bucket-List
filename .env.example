# Фронтенд переменные
VITE_API_URL=http://localhost:8000/api
VITE_APP_TITLE=Delting

# Бэкенд переменные
SECRET_KEY=ключ
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
TMDB_API_KEY=ключ
GOOGLE_PLACES_API_KEY=ключ
KINOPOISK_API_KEY=ключ

# База данных PostgreSQL
DATABASE_NAME=bucket_list
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_HOST=host
DATABASE_PORT=

# Пути к файлам
MEDIA_ROOT=/путь/к/вашему/проекту/backend/media
STATIC_ROOT=/путь/к/вашему/проекту/backend/static

# Фронтенд переменные
VITE_API_URL=http://localhost:8000
VITE_APP_TITLE=Delting
NEXT_PUBLIC_YANDEX_API_KEY=key
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# Yandex.Metrika (только для production, пустое значение отключает счётчик)
VITE_YANDEX_METRIKA_ID=

# Реквизиты оператора ПДн для юридических документов (самозанятый)
VITE_OPERATOR_FULL_NAME=
VITE_OPERATOR_INN=
VITE_OPERATOR_LOCATION=Российская Федерация
VITE_OPERATOR_PD_RESPONSIBLE=
VITE_OPERATOR_RKN_REGISTRY_NUMBER=

# ЮKassa (подписка Premium)
# Локально: YOOKASSA_USE_TEST_SHOP=True + ключи тестового магазина
# Продакшен: YOOKASSA_USE_TEST_SHOP=False + YOOKASSA_SHOP_ID / YOOKASSA_SECRET_KEY
SITE_URL=https://www.delting.ru
YOOKASSA_USE_TEST_SHOP=True
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_TEST_SHOP_ID=
YOOKASSA_TEST_SECRET_KEY=
# Проверять IP отправителя webhook (рекомендуется на проде)
YOOKASSA_VERIFY_NOTIFICATION_IP=False
